{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=agent_memory.db"
  },
  "Embeddings": {
    "Endpoint": "http://localhost:11434/v1",
    "Model": "mxbai-embed-large",
    "Dimensions": 1024,
    "ApiKey": "test123"
  },
  "Chat": {
    "Endpoint": "http://localhost:11434/v1",
    "Model": "qwen2.5:7b",
    "ApiKey": "test123",
    "Instructions": "You are Alfred, the manager agent. Delegate inbox organization, summarization, and calendar extraction tasks to the specialist workflow when the user asks about email."
  },
  "Google": {
    "CredentialsPath": "secrets/google-oauth-client.json",
    "TokenDirectory": ".tokens/google-workspace",
    "ApplicationName": "SpringAI2026 Email Organizer",
    "EnableGoogleCalendarWrite": false,
    "CalendarId": "primary"
  },
  "EmailProcessing": {
    "DefaultQuery": "in:inbox",
    "DefaultSyncCount": 10,
    "ApplyGmailLabelsByDefault": true,
    "AddEventsToLocalCalendarByDefault": true,
    "AddEventsToGoogleCalendarByDefault": false
  }
}
